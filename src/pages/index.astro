---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Button from '../components/Button.astro';
import Section from '../components/Section.astro';
import StatBox from '../components/StatBox.astro';
import PricingCard from '../components/PricingCard.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';

const DEMO_URL = 'https://meetings.hubspot.com/daar5014';
const WHATSAPP_URL =
  'https://wa.me/573159281379?text=' + encodeURIComponent('Hola, quiero conocer Livvo');

const stats = [
  { value: '<1 min', label: 'Tiempo de respuesta' },
  { value: '100%', label: 'Leads atendidos' },
  { value: '+40%', label: 'Citas el primer mes' },
  { value: '24/7', label: 'Cobertura total' },
];

const plans = [
  {
    name: 'Gratis',
    price: '$0',
    tagline: 'Empieza gratis y prueba la IA sin riesgo',
    features: [
      'Hasta 10 propiedades publicadas',
      'Descripciones con IA',
      'CRM (leads + propietarios)',
      'Calendario de citas',
      'Analíticas y reportes',
    ],
    featured: false,
    ctaLabel: 'Empezar gratis',
  },
  {
    name: 'Básico',
    price: '$200.000',
    tagline: 'Para arrancar con ventas automáticas en WhatsApp',
    features: [
      'Hasta 25 propiedades',
      '500 conversaciones/mes',
      'CRM (leads + propietarios)',
      'Calendario de citas',
      'Analíticas y reportes',
      'Todo lo del plan Gratis',
    ],
    featured: true,
    ctaLabel: 'Agendar demo →',
  },
  {
    name: 'Pro',
    price: '$507.000',
    tagline: 'Para escalar tu operación comercial',
    features: [
      'Hasta 50 propiedades',
      '1.500 conversaciones/mes',
      'CRM (leads + propietarios)',
      'Calendario de citas',
      'Analíticas y reportes',
      'Todo lo del plan Básico',
    ],
    featured: false,
    ctaLabel: 'Agendar demo',
  },
];

const faqItems = [
  {
    q: '¿Qué hace exactamente Livvo?',
    a: 'Livvo es un agente de IA que conversa con tus leads por WhatsApp, los califica según presupuesto, zona y capacidad de pago, y les recomienda inmuebles personalizados. El objetivo es eliminar el trabajo operativo de tu equipo y aumentar tu tasa de cierre.',
  },
  {
    q: '¿Se necesita un CRM previo?',
    a: 'No. Livvo incluye un portal donde puedes hacer seguimiento a tus leads y monitorear tus métricas comerciales. Si ya tienes un CRM, también nos integramos con él.',
  },
  {
    q: '¿Cuánto tiempo toma implementarlo?',
    a: 'Entre 1 y 3 días dependiendo de la personalización. Incluye entrenamiento del agente y conexión con WhatsApp Business API.',
  },
  {
    q: '¿Y si el bot suena robótico y espanta a mis clientes?',
    a: 'Livvo usa IA conversacional que se adapta al tono de tu inmobiliaria. Entrenamos el agente con el lenguaje real de tu equipo y del sector. Si en la demo no te convence cómo suena, no pagas nada.',
  },
  {
    q: '¿Qué pasa si quiero cancelar?',
    a: 'No hay contrato de permanencia — cancelas cuando quieras, sin penalidades. Te acompañamos durante la implementación para asegurarnos de que veas resultados desde el primer mes.',
  },
];
---

<Base>
  <Navbar />

  <!-- ESCENA HERO + CONVERSACIÓN — anillos concéntricos como escenario común -->
  <div class="hero-scene">
    <div id="hero-particles" class="hero-scene__particles" aria-hidden="true"></div>
    <header class="hero">
      <div class="container-site hero__inner">
        <div class="hero__content" id="hero-content">
          <h1 class="hero__title">
            Automatiza tu proceso comercial y <em class="grad-text">vende más.</em>
          </h1>
          <p class="hero__sub">
            Descubre cómo Luisa, la inteligencia artificial de Livvo, precalifica y agenda leads
            24/7 aumentando citas y disminuyendo trabajo manual.
          </p>
          <div class="hero__ctas">
            <Button href={WHATSAPP_URL} target="_blank" size="lg" id="hero-demo-cta">Conversar con Livvo →</Button>
          </div>
        </div>
      </div>
    </header>

    <section class="hero-chat">
      <div class="hero-chat__bg" id="chat-rings" aria-hidden="true">
        <svg class="hero-chat__circles" viewBox="0 0 200 200" fill="none" stroke="currentColor">
          <circle cx="100" cy="100" r="90" stroke-width="0.35" stroke-dasharray="2 3" />
          <circle cx="100" cy="100" r="68" stroke-width="0.35" />
          <circle cx="100" cy="100" r="46" stroke-width="0.4" stroke-dasharray="1 2" />
          <circle cx="100" cy="100" r="24" stroke-width="0.5" stroke="#00C7B4" opacity="0.35" />
        </svg>
      </div>
      <div class="container-site hero-chat__inner">
        <div class="hero-chat__stage" id="chat-stage">
          <iframe
            src="/livvo-whatsapp.html"
            width="424"
            height="740"
            loading="lazy"
            scrolling="no"
            title="Conversación de WhatsApp con Luisa, la IA de Livvo"
            class="hero-chat__frame"></iframe>
        </div>
      </div>
    </section>
  </div>

  <!-- IMPACTO -->
  <Section id="impacto" eyebrow="Impacto medible" title="Números, no promesas." alt>
    <div class="stats-grid fade-up">
      {stats.map(({ value, label }) => <StatBox {value} {label} />)}
    </div>
  </Section>

  <!-- PRECIOS -->
  <Section id="precios" eyebrow="Planes" title="Empieza gratis. Escala cuando quieras.">
    <div class="pricing-grid fade-up">
      {
        plans.map((plan) => (
          <PricingCard
            name={plan.name}
            price={plan.price}
            tagline={plan.tagline}
            features={plan.features}
            featured={plan.featured}
            ctaLabel={plan.ctaLabel}
            ctaHref={DEMO_URL}
            ctaTarget="_blank"
          />
        ))
      }
    </div>
    <div class="pricing-terms fade-up">
      <span>Prueba gratuita de 7 días</span>
      <span>Sin tarjeta de crédito</span>
      <span>Facturación en pesos colombianos</span>
    </div>
  </Section>

  <!-- FAQ -->
  <Section id="faq" eyebrow="FAQ" title="Preguntas frecuentes" alt>
    <div class="fade-up">
      <FAQ items={faqItems} />
    </div>
  </Section>

  <!-- CTA FINAL -->
  <Section id="contacto">
    <div class="cta-final fade-up">
      <span class="eyebrow">Empieza hoy</span>
      <h2>¿Listo para dejar de perder leads?</h2>
      <p>
        Agenda una demo de 15 minutos y mira a Livvo responder, calificar y agendar con propiedades
        reales de tu portafolio.
      </p>
      <Button href={DEMO_URL} target="_blank" size="lg" id="final-demo-cta">Agendar demo →</Button>
    </div>
  </Section>

  <Footer />
</Base>

<script>
  // Partículas teal del DS: pocas, pequeñas, deriva lenta y parpadeo sutil.
  // Sin top-level await: si algo falla o se cuelga, no bloquea el módulo.
  import { tsParticles } from '@tsparticles/engine';
  import { loadSlim } from '@tsparticles/slim';

  const initParticles = async () => {
    await loadSlim(tsParticles);
    await tsParticles.load({
      id: 'hero-particles',
      options: {
        fullScreen: { enable: false },
        background: { color: 'transparent' },
        fpsLimit: 60,
        detectRetina: true,
        particles: {
          number: { value: 18, density: { enable: false } },
          color: { value: '#00C7B4' },
          shape: { type: 'circle' },
          opacity: {
            value: { min: 0.12, max: 0.55 },
            animation: { enable: true, speed: 0.5, sync: false },
          },
          size: { value: { min: 2, max: 4 } },
          move: {
            enable: true,
            speed: 0.35,
            direction: 'none',
            random: true,
            straight: false,
            outModes: { default: 'out' },
          },
        },
        interactivity: {
          events: { onHover: { enable: false }, onClick: { enable: false }, resize: { enable: true } },
        },
      },
    });
  };

  if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
    initParticles().catch((e) => console.error('[particles] error:', e));
  }
</script>

<script>
  // Escena hero → teléfono ligada al scroll (estilo useplaza):
  // el teléfono asoma en la primera pantalla y sube/escala mientras
  // el texto del hero se desvanece. Sin librerías: scroll + rAF.
  const stage = document.getElementById('chat-stage');
  const heroContent = document.getElementById('hero-content');
  const rings = document.getElementById('chat-rings');
  const reducedMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (stage && heroContent && !reducedMotion) {
    let ticking = false;

    const update = () => {
      ticking = false;
      const progress = Math.min(1, Math.max(0, scrollY / (innerHeight * 0.55)));
      const eased = 1 - Math.pow(1 - progress, 2); // ease-out

      stage.style.transform = `translateY(${(1 - eased) * 90}px) scale(${0.9 + eased * 0.1})`;
      stage.style.opacity = String(0.5 + eased * 0.5);

      heroContent.style.opacity = String(1 - eased * 0.9);
      heroContent.style.transform = `translateY(${-eased * 40}px)`;

      // los anillos ganan presencia y se expanden levemente con el scroll
      if (rings) {
        rings.style.opacity = String(0.4 + eased * 0.6);
        rings.style.transform = `translate(-50%, -50%) scale(${0.92 + eased * 0.08})`;
      }
    };

    addEventListener('scroll', () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    }, { passive: true });

    // al terminar la entrada, soltar la animación CSS para que los estilos
    // inline del scroll tomen el control (una animación activa los pisa)
    heroContent.addEventListener(
      'animationend',
      () => {
        heroContent.style.animation = 'none';
        update();
      },
      { once: true }
    );
    update();
  }
</script>

<style>
  /* La escena contiene hero + chat y aporta el fondo; los anillos
     pueden desbordar entre secciones sin salirse de la escena */
  .hero-scene {
    position: relative;
    overflow: hidden;
    background: var(--white);
    transition: background-color var(--transition);
  }

  /* Partículas teal (patrón del DS: dispersas, energía ambiental) */
  .hero-scene__particles {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .hero {
    /* deja ~30vh libres al fondo de la primera pantalla para que el teléfono asome */
    min-height: calc(70vh - 68px);
    display: flex;
    align-items: flex-start;
    background: transparent;
    position: relative;
    z-index: 2;
    padding: 14vh 0 0;
  }
  .hero__inner { width: 100%; }
  .hero__content {
    text-align: center;
    max-width: 880px;
    margin: 0 auto;
    animation: hero-in 0.7s ease both;
    will-change: transform, opacity;
  }
  @keyframes hero-in {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: none; }
  }
  .hero__title {
    font-size: clamp(38px, 5vw, 68px);
    letter-spacing: -1.5px;
    line-height: 1.1;
    margin: 0 0 var(--space-6);
  }
  .hero__title em { font-style: normal; }
  .hero__sub {
    font-size: var(--text-body);
    line-height: var(--lh-relaxed);
    color: var(--muted);
    max-width: 560px;
    margin: 0 auto var(--space-8);
  }
  .hero__ctas { display: flex; justify-content: center; gap: var(--space-4); flex-wrap: wrap; }

  .hero-chat { padding: 24px 0 96px; background: transparent; position: relative; }
  .hero-chat__inner { display: flex; justify-content: center; position: relative; z-index: 1; }
  .hero-chat__stage {
    transform-origin: top center;
    will-change: transform, opacity;
  }
  .hero-chat__frame { border: 0; max-width: 100%; display: block; }

  /* Anillos concéntricos (patrón del DS) centrados donde aterriza el teléfono */
  .hero-chat__bg {
    position: absolute;
    left: 50%;
    top: 44%;
    width: min(1100px, 170vw);
    height: min(1100px, 170vw);
    transform: translate(-50%, -50%);
    color: var(--border);
    pointer-events: none;
    z-index: 0;
    will-change: transform, opacity;
  }
  /* máscara radial: los anillos se desvanecen hacia los bordes */
  .hero-chat__bg::after {
    content: '';
    position: absolute;
    inset: -2px;
    background: radial-gradient(circle at center, transparent 30%, var(--white) 78%);
  }
  .hero-chat__circles {
    width: 100%;
    height: 100%;
    display: block;
    animation: rings-spin 140s linear infinite;
  }
  @keyframes rings-spin {
    to { transform: rotate(360deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__content { animation: none; }
    .hero-chat__circles { animation: none; }
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    align-items: stretch;
  }
  .pricing-terms {
    display: flex;
    justify-content: center;
    gap: var(--space-8);
    flex-wrap: wrap;
    margin-top: var(--space-12);
    font-size: 13px;
    color: var(--muted);
  }

  .cta-final { text-align: center; max-width: 620px; margin: 0 auto; }
  .cta-final h2 { margin: var(--space-4) 0; }
  .cta-final p { color: var(--muted); margin-bottom: var(--space-8); }

  @media (max-width: 1024px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .pricing-grid { grid-template-columns: 1fr; max-width: 440px; margin-inline: auto; }
  }
</style>

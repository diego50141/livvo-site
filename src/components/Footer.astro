---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container-site footer__inner">
    <a href="/" class="footer__logo">livv<span>o</span><span>·</span></a>
    <div class="footer__links">
      <a href="#producto">Producto</a>
      <a href="#precios">Precios</a>
      <a href="#faq">FAQ</a>
      <a href="https://meetings.hubspot.com/daar5014" target="_blank" rel="noopener">Agendar demo</a>
    </div>
    <div class="footer__copy">© {year} Livvo · livvo.tech</div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: var(--space-12) 0;
    background: var(--gray-bg);
  }
  .footer__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    flex-wrap: wrap;
  }
  .footer__logo {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 800;
    color: var(--navy);
    text-decoration: none;
  }
  .footer__logo span { color: var(--teal); }
  .footer__links { display: flex; gap: var(--space-6); flex-wrap: wrap; }
  .footer__links a {
    font-size: 14px;
    color: var(--muted);
    text-decoration: none;
  }
  .footer__links a:hover { color: var(--navy); }
  .footer__copy { font-size: 13px; color: var(--muted); font-family: var(--font-mono); }
</style>

---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container-site footer__inner">
    <a href="/" class="footer__logo">
      <svg class="footer__symbol" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <polyline points="24,20 43,80 62,20" fill="none" stroke="currentColor" stroke-width="11.5" stroke-linecap="round" stroke-linejoin="round"/>
        <polyline points="40,20 59,80 78,20" fill="none" stroke="#00C7B4" stroke-width="11.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      livv<span>o</span><span>·</span>
    </a>
    <div class="footer__links">
      <a href="#producto">Producto</a>
      <a href="#precios">Precios</a>
      <a href="#faq">FAQ</a>
      <a href="https://meetings.hubspot.com/daar5014" target="_blank" rel="noopener">Agendar demo</a>
    </div>
    <div class="footer__copy">© {year} Livvo · livvo.tech</div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: var(--space-12) 0;
    background: var(--gray-bg);
  }
  .footer__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    flex-wrap: wrap;
  }
  .footer__logo {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 800;
    color: var(--navy);
    text-decoration: none;
  }
  .footer__symbol { height: 22px; width: auto; display: block; }
  .footer__logo span { color: var(--teal); }
  .footer__links { display: flex; gap: var(--space-6); flex-wrap: wrap; }
  .footer__links a {
    font-size: 14px;
    color: var(--muted);
    text-decoration: none;
  }
  .footer__links a:hover { color: var(--navy); }
  .footer__copy { font-size: 13px; color: var(--muted); font-family: var(--font-mono); }
</style>

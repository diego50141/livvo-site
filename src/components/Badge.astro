---
interface Props {
  variant?: 'solid' | 'outline';
}

const { variant = 'solid' } = Astro.props;
---

<span class:list={['badge', `badge--${variant}`]}><slot /></span>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 20px;
  }
  .badge--solid { background: var(--grad-cta); color: #fff; }
  .badge--outline {
    border: 1.5px solid var(--teal);
    color: var(--teal-deep);
    background: rgba(0, 199, 180, 0.06);
  }
</style>
